datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  isAdmin       Boolean             @default(false)
  createdAt     DateTime            @default(now())
  tokens        AuthToken[]
  registrations EventRegistration[]
}

model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MenuItem {
  id            String   @id @default(uuid())
  name          String
  category      String
  ingredients   String[]
  description   String   @default("")
  price         Float
  buyingPrice   Float    @default(0)
  inStock       Boolean  @default(true)
  visibleInMenu Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InventoryItem {
  id                String   @id @default(uuid())
  name              String
  category          String   @default("")
  supplier          String   @default("")
  size              String   @default("")
  pricePerUnit      Float    @default(0)
  costPerDosage     Float    @default(0)
  dosageDescription String   @default("")
  quantity          Float    @default(0)
  unit              String   @default("gab.")
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Event {
  id                   String              @id @default(uuid())
  title                String
  type                 String
  date                 DateTime
  guide                String              @default("")
  description          String              @default("")
  cost                 Float?
  spots                Int?
  requiresRegistration Boolean             @default(false)
  visible              Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  registrations        EventRegistration[]
}

model OpeningHours {
  dayOfWeek    Int     @id // 1=Monday … 7=Sunday
  morningOpen  String?
  morningClose String?
  eveningOpen  String?
  eveningClose String?
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}
